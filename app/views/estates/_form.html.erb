                    <%= form.text_field :vrsta, class: "form-control" %>
                  </div>
                </div>

                <div class="form-group row">
                  <%= form.label :tip, class: "col-md-4 col-form-label text-md-right" %>
                  <div class="col-md-6">
                    <%= form.text_field :tip, class: "form-control" %>
