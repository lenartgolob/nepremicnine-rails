        </div>

        <div class="form-group row">
        <%= form.label :opis1, class: "col-md-4 col-form-label text-md-right" %>
        <div class="col-md-6">
          <%= form.text_field :opis1, class: "form-control" %>
        </div>
      </div>

      <div class="form-group row">
      <%= form.label :opis2, class: "col-md-4 col-form-label text-md-right" %>
