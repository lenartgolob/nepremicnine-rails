        <%= form.text_field :opis2, class: "form-control" %>
      </div>
    </div>






                <div class="actions col-md-6 offset-md-4">
                  <%= form.submit "Objavi", class: "btn btn-primary" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
